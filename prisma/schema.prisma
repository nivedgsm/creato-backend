datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CREATOR
  BRAND
  ADMIN
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApplicationRequirement {
  OPEN
  VERIFIED_ONLY
}

enum CampaignParticipationType {
  OPEN
  APPROVAL_REQUIRED
}

enum AdminActionType {
  CAMPAIGN_APPROVED
  CAMPAIGN_CANCELLED
  USER_DISABLED
  USER_ENABLED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(CREATOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Brand → Campaigns
  campaigns Campaign[] @relation("BrandCampaigns")

  // Creator → Applications
  applications CampaignApplication[] @relation("CreatorApplications")

  // Profiles
  creatorProfile CreatorProfile?
  brandProfile   BrandProfile?

  // Audit logs
  adminAuditLogs    AdminAuditLog[]
  targetedAuditLogs AdminAuditLog[] @relation("AdminAuditTargetUser")

  // 🔥 Instagram + Reels
  instagramAccount InstagramAccount?
  reelSubmissions  ReelSubmission[]
}

model Campaign {
  id          String @id @default(uuid())
  title       String
  description String

  requirements String?
  budget       String?

  payoutPer100kViews Float?
  totalBudget        Float?

  googleDriveLink String?
  megaLink        String?
  youtubeLink     String?
  instagramLink   String?
  otherLinks      String?

  status CampaignStatus @default(DRAFT)

  requiresAdminApproval   Boolean @default(true)
  requiresCreatorApproval Boolean @default(false)

  applicationRequirement ApplicationRequirement    @default(OPEN)
  participationType      CampaignParticipationType @default(APPROVAL_REQUIRED)

  brandId String
  brand   User   @relation("BrandCampaigns", fields: [brandId], references: [id])

  applications    CampaignApplication[]
  adminAuditLogs  AdminAuditLog[]
  reelSubmissions ReelSubmission[]

  createdAt DateTime @default(now())
}

model CampaignApplication {
  id String @id @default(uuid())

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  creatorId String
  creator   User   @relation("CreatorApplications", fields: [creatorId], references: [id])

  status ApplicationStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@unique([campaignId, creatorId])
}

model CreatorProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  displayName     String
  username        String
  profileImageUrl String?

  bio      String
  category String

  primaryPlatform String
  followersCount  Int
  avgViews        Int?
  engagementRate  Float?

  country  String
  city     String?
  language String

  instagramUrl String?
  youtubeUrl   String?
  twitterUrl   String?
  websiteUrl   String?

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrandProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  brandName  String
  logoUrl    String?
  websiteUrl String?

  description String
  industry    String

  companySize String
  foundedYear Int?

  contactEmail      String
  contactPersonName String?

  country String
  city    String?

  verified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminAuditLog {
  id      String          @id @default(uuid())
  adminId String
  action  AdminActionType

  campaignId     String?
  previousStatus CampaignStatus?
  newStatus      CampaignStatus?

  targetUserId String?

  createdAt DateTime @default(now())

  admin      User      @relation(fields: [adminId], references: [id])
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  targetUser User?     @relation("AdminAuditTargetUser", fields: [targetUserId], references: [id])

  @@index([adminId])
  @@index([campaignId])
  @@index([targetUserId])
  @@index([createdAt])
}

model InstagramAccount {
  id          String @id
  username    String
  accessToken String

  userId String @unique // 👈 THIS fixes it
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model ReelSubmission {
  id         String @id @default(uuid())
  campaignId String
  creatorId  String

  igMediaId String
  igUrl     String

  status String @default("TRACKING")

  views      Int @default(0)
  reach      Int @default(0)
  likes      Int @default(0)
  comments   Int @default(0)
  videoPlays Int @default(0)

  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])
  creator  User     @relation(fields: [creatorId], references: [id])

  @@unique([campaignId, creatorId, igMediaId])
}


model CampaignSlab {
  id         String   @id @default(uuid())
  campaignId String
  views      Int      // eg 5000, 25000, 100000
  payout     Int      // eg 500, 2000, 6000

  campaign   Campaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, views])
}

