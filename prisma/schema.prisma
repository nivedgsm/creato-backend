datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/* =======================
   ENUMS
======================= */

enum Role {
  CREATOR
  BRAND
  ADMIN
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApplicationRequirement {
  OPEN
  VERIFIED_ONLY
}

enum CampaignParticipationType {
  OPEN
  APPROVAL_REQUIRED
}

enum AdminActionType {
  CAMPAIGN_APPROVED
  CAMPAIGN_CANCELLED
  USER_DISABLED
  USER_ENABLED
}

enum ReelStatus {
  PENDING
  TRACKING
  PAID
  REJECTED
}

enum WalletTransactionType {
  SLAB_EARNED
  SLAB_REVERSED
  WITHDRAWAL
}

enum WalletTxStatus {
  PENDING
  CLEARED
  REVERSED
}

/* =======================
   USERS
======================= */

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(CREATOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  campaigns    Campaign[]            @relation("BrandCampaigns")
  applications CampaignApplication[] @relation("CreatorApplications")

  creatorProfile CreatorProfile?
  brandProfile   BrandProfile?

  adminAuditLogs    AdminAuditLog[]
  targetedAuditLogs AdminAuditLog[] @relation("AdminAuditTargetUser")

  instagramAccount InstagramAccount?
  reelSubmissions  ReelSubmission[]
  wallet           Wallet?
}

/* =======================
   CAMPAIGNS
======================= */

model Campaign {
  id          String @id @default(uuid())
  title       String
  description String

  requirements String?
  budget       String?

  totalBudget Float
  platformFee Float
  creatorPool Float

  googleDriveLink String?
  megaLink        String?
  youtubeLink     String?
  instagramLink   String?
  otherLinks      String?

  status CampaignStatus @default(DRAFT)

  requiresAdminApproval   Boolean @default(true)
  requiresCreatorApproval Boolean @default(false)

  applicationRequirement ApplicationRequirement    @default(OPEN)
  participationType      CampaignParticipationType @default(APPROVAL_REQUIRED)

  brandId String
  brand   User @relation("BrandCampaigns", fields: [brandId], references: [id])

  applications    CampaignApplication[]
  adminAuditLogs  AdminAuditLog[]
  reelSubmissions ReelSubmission[]
  slabs           CampaignSlab[] @relation("CampaignSlabs")

  createdAt DateTime @default(now())
}

/* =======================
   SLABS
======================= */

model CampaignSlab {
  id         String @id @default(uuid())
  campaignId String

  views  Int
  payout Int

  campaign Campaign @relation("CampaignSlabs", fields: [campaignId], references: [id])

  @@unique([campaignId, views])
}

/* =======================
   APPLICATIONS
======================= */

model CampaignApplication {
  id String @id @default(uuid())

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  creatorId String
  creator   User @relation("CreatorApplications", fields: [creatorId], references: [id])

  status ApplicationStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@unique([campaignId, creatorId])
}

/* =======================
   REELS
======================= */
model ReelSubmission {
  id         String @id @default(uuid())
  campaignId String
  creatorId  String

  igMediaId String?
  igUrl     String?

  status     ReelStatus @default(PENDING)

  videoPlays Int      @default(0)   // 👈 correct metric
  reach      Int      @default(0)
  likes      Int      @default(0)
  comments   Int      @default(0)
  earnings   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])
  creator  User     @relation(fields: [creatorId], references: [id])

  walletTransactions WalletTransaction[]

  @@unique([igMediaId])
}


/* =======================
   PROFILES
======================= */

model CreatorProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  displayName     String
  username        String
  profileImageUrl String?
  bio             String
  category        String

  primaryPlatform String
  followersCount  Int
  avgViews        Int?
  engagementRate  Float?

  country  String
  city     String?
  language String

  instagramUrl String?
  youtubeUrl   String?
  twitterUrl   String?
  websiteUrl   String?

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrandProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  brandName  String
  logoUrl    String?
  websiteUrl String?
  description String
  industry    String

  companySize String
  foundedYear Int?

  contactEmail      String
  contactPersonName String?

  country String
  city    String?

  verified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/* =======================
   ADMIN AUDIT
======================= */

model AdminAuditLog {
  id      String @id @default(uuid())
  adminId String
  action  AdminActionType

  campaignId     String?
  previousStatus CampaignStatus?
  newStatus      CampaignStatus?

  targetUserId String?

  createdAt DateTime @default(now())

  admin      User      @relation(fields: [adminId], references: [id])
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  targetUser User?     @relation("AdminAuditTargetUser", fields: [targetUserId], references: [id])

  @@index([adminId])
  @@index([campaignId])
  @@index([targetUserId])
  @@index([createdAt])
}

/* =======================
   INSTAGRAM
======================= */

model InstagramAccount {
  id          String @id
  username    String
  accessToken String

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

/* =======================
   WALLETS
======================= */

model Wallet {
  id      String @id @default(uuid())
  userId  String @unique
  balance Int    @default(0)
  pending Int    @default(0)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  walletTransactions WalletTransaction[]
}

model WalletTransaction {
  id       String @id @default(uuid())
  walletId String
  reelId   String?

  amount Int
  type   WalletTransactionType
  status WalletTxStatus

  wallet Wallet          @relation(fields: [walletId], references: [id])
  reel   ReelSubmission? @relation(fields: [reelId], references: [id])

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([reelId])
}
